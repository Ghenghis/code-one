{
  "permissions": {
    "allow": [
      "Bash(pnpm --version)",
      "Bash(npm --version)",
      "Bash(pnpm add:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(find . -name \"package.json\" -not -path \"*/node_modules/*\" -exec grep -l \"hybrid-ide\" {} \\\\;)",
      "Bash(find . -name \"package.json\" -not -path \"*/node_modules/*\" -exec sed -i 's/@hybrid-ide\\\\//@code-one\\\\//g' {} \\\\;)",
      "Bash(find . -name \"index.ts\" -not -path \"*/node_modules/*\" -exec sed -i 's/@hybrid-ide\\\\//@code-one\\\\//g' {} \\\\;)"
    ]
  }
}
